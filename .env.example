# Supabase (create project at https://supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Sheets as listings source (when Supabase is not used)
# 1. Create a Google Sheet with columns: title, developer, project, location, unit_type, area, rooms, toilets, downpayment, monthly_inst, price, finishing, delivery, featured, images, area_slug
# 2. File > Share > Publish to web > Link > CSV
# 3. Copy the Sheet ID from the URL (the part between /d/ and /edit)
# VITE_GOOGLE_SHEET_ID=your-sheet-id

# Optional: control panel password (default in code is arabianestate@tdm)
# VITE_CONTROL_PASSWORD=arabianestate@tdm

# Optional: Conversion tracking (1 lead per session on first WhatsApp or Call click)
#
# Option A – Google Tag Manager (recommended): one tag, manage everything in GTM
#   Set VITE_GTM_ID=GTM-XXXXXX (from tagmanager.google.com). We push dataLayer event "lead".
#   In GTM: Trigger = Custom Event, Event name = "lead" → add Google Ads conversion + Facebook Lead tags.
#
# VITE_GTM_ID=GTM-XXXXXX
#
# Option B – Direct gtag (no GTM): set both below
#   VITE_GOOGLE_ADS_ID=AW-XXXXXXXXXX
#   VITE_GOOGLE_ADS_CONVERSION_SEND_TO=AW-XXXXXXXXXX/ConversionLabel  (from Ads > Goals > Conversions > Tag setup)
#
# VITE_GOOGLE_ADS_ID=AW-XXXXXXXXXX
# VITE_GOOGLE_ADS_CONVERSION_SEND_TO=AW-XXXXXXXXXX/ConversionLabel
#
# Option C – Meta (Facebook) Pixel (or add it in GTM)
# VITE_FACEBOOK_PIXEL_ID=XXXXXXXXXXXXXXX
